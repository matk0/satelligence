# Database
DB_PASSWORD=your_secure_password
DATABASE_URL=postgres://trandor:your_secure_password@localhost:5432/trandor?sslmode=disable

# Blink API (Lightning payments)
# Two separate accounts to keep agent deposits separate from Trandor revenue:
# - BLINK_API_KEY_AGENTS: Backs LNbits wallets for agent deposits
# - BLINK_API_KEY_REVENUE: Receives payments when agents use the API
# Create both at https://dashboard.blink.sv
BLINK_API_KEY_AGENTS=your_blink_api_key_for_agent_wallets
BLINK_API_KEY_REVENUE=your_blink_api_key_for_trandor_revenue

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# Macaroon signing secret (generate with: openssl rand -hex 32)
MACAROON_SECRET=your_32_byte_hex_secret

# Rails (generate with: rails secret)
SECRET_KEY_BASE=your_rails_secret_key_base

# Optional API configuration
MARKUP_PERCENT=5
MIN_DEPOSIT_SATS=5000

# Server ports
API_PORT=8080
WEB_PORT=3000

# LNbits (hosted wallets) - get this from your LNbits super admin account
LNBITS_ADMIN_KEY=your_lnbits_super_admin_key
