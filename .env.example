# Database (DigitalOcean Managed PostgreSQL)
DATABASE_URL=postgres://user:password@host:25060/satilligence?sslmode=require

# Blink API
BLINK_API_KEY=your_blink_api_key

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# Macaroon signing secret (generate with: openssl rand -hex 32)
MACAROON_SECRET=your_32_byte_hex_secret

# Optional configuration
MARKUP_PERCENT=5
MIN_DEPOSIT_SATS=5000
RATE_LIMIT_RPM=60
MAX_STRIKES=3

# Server
PORT=8080
