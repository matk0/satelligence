www.trandor.com {
    # Web app
    reverse_proxy web:80
}

# API subdomain - direct to Go backend
api.trandor.com {
    reverse_proxy api:8080
}

# Redirect non-www to www
trandor.com {
    redir https://www.trandor.com{uri} permanent
}

# Nostr relay (for NWC WebSocket connections)
relay.trandor.com {
    reverse_proxy nostr-relay:8080
}
