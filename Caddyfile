www.trandor.com {
    # Web app
    reverse_proxy web:80
}

# API subdomain - direct to Go backend
api.trandor.com {
    reverse_proxy api:8080
}

# Redirect non-www to www
trandor.com {
    redir https://www.trandor.com{uri} permanent
}

# Nostr relay (for NWC WebSocket connections)
# Proxies to LNbits nostrclient extension which acts as relay multiplexer
relay.trandor.com {
    rewrite * /nostrclient/api/v1/relay
    reverse_proxy lnbits:5000
}

# LNbits admin UI
lnbits.trandor.com {
    reverse_proxy lnbits:5000
}
