<div class="min-h-screen bg-slate-900 flex flex-col" data-controller="chat">
  <!-- Header -->
  <header class="border-b border-slate-700 flex-shrink-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center justify-between">
        <%= link_to root_path, class: "text-xl font-bold text-yellow-400" do %>
          &#x26A1; Satilligence
        <% end %>

        <div class="flex items-center gap-4">
          <!-- Wallet Status -->
          <div id="wallet-status" class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-red-500" data-chat-target="statusDot"></span>
            <span class="text-sm text-gray-400" data-chat-target="statusText">Not connected</span>
          </div>

          <!-- Connect Button -->
          <button
            data-action="click->chat#connectWallet"
            data-chat-target="connectBtn"
            class="px-4 py-2 bg-yellow-500 hover:bg-yellow-400 text-black font-semibold rounded-lg text-sm transition-all"
          >
            Connect Wallet
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- Chat Area -->
  <main class="flex-1 overflow-hidden flex flex-col max-w-4xl mx-auto w-full">
    <!-- Messages -->
    <div
      class="flex-1 overflow-y-auto p-4 space-y-4"
      data-chat-target="messages"
    >
      <!-- Welcome message -->
      <div class="text-center py-12">
        <div class="text-6xl mb-4">&#x26A1;</div>
        <h2 class="text-2xl font-bold text-white mb-2">Welcome to Satilligence</h2>
        <p class="text-gray-400 max-w-md mx-auto">
          Connect your Lightning wallet to start chatting with AI.
          Pay per request - no accounts needed.
        </p>
      </div>
    </div>

    <!-- Input Area -->
    <div class="border-t border-slate-700 p-4 flex-shrink-0">
      <!-- Model Selector -->
      <div class="flex items-center gap-4 mb-4">
        <label class="text-sm text-gray-400">Model:</label>
        <select
          data-chat-target="modelSelect"
          class="bg-slate-800 text-white border border-slate-600 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-yellow-500"
        >
          <option value="gpt-4o-mini">GPT-4o Mini (cheapest)</option>
          <option value="gpt-4o">GPT-4o</option>
          <option value="gpt-4-turbo">GPT-4 Turbo</option>
        </select>

        <div class="ml-auto text-sm text-gray-500" data-chat-target="costInfo">
          <!-- Cost info will appear here -->
        </div>
      </div>

      <!-- Message Input -->
      <div class="flex gap-3">
        <textarea
          data-chat-target="input"
          data-action="keydown->chat#handleKeydown"
          placeholder="Type your message... (Ctrl+Enter to send)"
          rows="3"
          class="flex-1 bg-slate-800 text-white border border-slate-600 rounded-lg px-4 py-3 resize-none focus:outline-none focus:border-yellow-500 disabled:opacity-50"
          disabled
        ></textarea>
        <button
          data-action="click->chat#sendMessage"
          data-chat-target="sendBtn"
          disabled
          class="px-6 py-3 bg-yellow-500 hover:bg-yellow-400 disabled:bg-slate-700 disabled:text-slate-500 text-black font-semibold rounded-lg transition-all self-end"
        >
          Send
        </button>
      </div>
    </div>
  </main>

  <!-- Connection Modal -->
  <div
    id="connection-modal"
    class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 hidden"
    data-chat-target="modal"
  >
    <div class="bg-slate-800 rounded-2xl p-8 max-w-md w-full mx-4 border border-slate-700">
      <h3 class="text-xl font-bold text-white mb-6">Connect Your Wallet</h3>

      <!-- WebLN Option -->
      <button
        data-action="click->chat#connectWebLN"
        class="w-full mb-4 p-4 bg-slate-700 hover:bg-slate-600 rounded-lg text-left transition-all border border-slate-600"
      >
        <div class="flex items-center gap-3">
          <div class="text-2xl">&#x1F9F2;</div>
          <div>
            <div class="text-white font-semibold">Alby Extension</div>
            <div class="text-sm text-gray-400">Connect via browser extension (WebLN)</div>
          </div>
        </div>
      </button>

      <!-- NWC Option -->
      <div class="mb-6">
        <label class="block text-sm text-gray-400 mb-2">Or paste your NWC connection string:</label>
        <textarea
          data-chat-target="nwcInput"
          placeholder="nostr+walletconnect://..."
          rows="3"
          class="w-full bg-slate-900 text-white border border-slate-600 rounded-lg px-4 py-3 text-sm resize-none focus:outline-none focus:border-yellow-500"
        ></textarea>
        <button
          data-action="click->chat#connectNWC"
          class="mt-3 w-full px-4 py-3 bg-yellow-500 hover:bg-yellow-400 text-black font-semibold rounded-lg transition-all"
        >
          Connect with NWC
        </button>
      </div>

      <button
        data-action="click->chat#closeModal"
        class="w-full px-4 py-2 text-gray-400 hover:text-white transition-all"
      >
        Cancel
      </button>
    </div>
  </div>
</div>
