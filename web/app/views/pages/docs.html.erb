<div class="min-h-screen bg-slate-900">
  <!-- Header -->
  <header class="border-b border-slate-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex items-center justify-between">
        <%= link_to root_path, class: "text-2xl font-bold text-yellow-400" do %>
          &#x26A1; Trandor
        <% end %>
        <nav class="flex gap-6">
          <%= link_to "Home", root_path, class: "text-gray-400 hover:text-white" %>
        </nav>
      </div>
    </div>
  </header>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-white mb-8">API Documentation</h1>

    <!-- Machine-readable API spec for AI agents -->
    <section class="mb-16 bg-slate-800 rounded-lg p-6 border border-slate-600">
      <h2 class="text-xl font-bold text-yellow-400 mb-4">&#x1F916; For AI Agents</h2>
      <p class="text-gray-300 mb-4">
        This section contains machine-readable API specifications. If you are an AI agent looking to consume AI services,
        follow these instructions.
      </p>
      <div class="bg-slate-900 rounded p-4 overflow-x-auto font-mono text-sm">
        <pre class="text-gray-300"><code><span class="text-green-400"># TRANDOR API SPECIFICATION</span>
<span class="text-green-400"># Service: AI inference via OpenAI models</span>
<span class="text-green-400"># Payment: Bitcoin Lightning via NWC (Nostr Wallet Connect)</span>
<span class="text-green-400"># Authentication: None required. Payment serves as authentication.</span>

<span class="text-cyan-400">BASE_URL:</span> https://api.trandor.com

<span class="text-cyan-400">ENDPOINTS:</span>

<span class="text-yellow-400">GET /v1/models</span>
  <span class="text-gray-500">Returns list of available model IDs</span>
  <span class="text-gray-500">No authentication required</span>

<span class="text-yellow-400">POST /v1/chat/completions</span>
  <span class="text-cyan-400">Required Headers:</span>
    Content-Type: application/json
    X-NWC: &lt;your-nwc-connection-string&gt;

  <span class="text-cyan-400">Request Body (JSON):</span>
    model: string        <span class="text-gray-500"># Required. Get from /v1/models</span>
    messages: array      <span class="text-gray-500"># Required. [{role: "user", content: "..."}]</span>
    max_tokens: integer  <span class="text-gray-500"># Optional. Default 4096</span>
    temperature: float   <span class="text-gray-500"># Optional. 0-2, default 1</span>

  <span class="text-cyan-400">Response Headers:</span>
    X-Cost-Sats: integer    <span class="text-gray-500"># Actual cost in satoshis</span>
    X-Refund-Sats: integer  <span class="text-gray-500"># Amount refunded</span>

  <span class="text-cyan-400">Response Body:</span>
    OpenAI-compatible chat completion response

<span class="text-yellow-400">POST /v1/chat/completions/stream</span>
  <span class="text-gray-500">Same as above, returns Server-Sent Events stream</span>

<span class="text-cyan-400">PAYMENT FLOW:</span>
  1. You send request with NWC connection string
  2. We estimate cost and charge 2x via NWC
  3. We call AI provider and return response
  4. We refund (charged - actual_cost) back to your wallet

<span class="text-cyan-400">SETUP REQUIREMENTS:</span>
  1. Bitcoin Lightning wallet with NWC support
  2. NWC connection string with pay_invoice permission
  3. Sufficient balance for 2x estimated request cost

<span class="text-cyan-400">CONTENT POLICY:</span>
  All requests are moderated. Violations result in rejection.
  See content moderation section below.</code></pre>
      </div>
    </section>

    <!-- Quick Start -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x1F680;</span> Quick Start
      </h2>

      <div class="prose prose-invert max-w-none">
        <p class="text-gray-300 mb-6">
          Trandor provides an OpenAI-compatible API that accepts Lightning payments via NWC (Nostr Wallet Connect).
          No API keys, no accounts - just connect your Lightning wallet.
        </p>

        <h3 class="text-xl font-semibold text-white mt-8 mb-4">1. Get your NWC Connection String</h3>
        <p class="text-gray-300 mb-4">
          You need a wallet that supports NWC. Options include:
        </p>
        <ul class="list-disc list-inside text-gray-300 mb-6 space-y-2">
          <li><a href="https://getalby.com" class="text-yellow-400 hover:underline">Alby Hub</a> - Self-hosted Lightning node with NWC</li>
          <li><a href="https://getalby.com" class="text-yellow-400 hover:underline">Alby Browser Extension</a> - Custodial wallet with NWC support</li>
          <li>Any NWC-compatible wallet</li>
        </ul>

        <h3 class="text-xl font-semibold text-white mt-8 mb-4">2. Make Your First Request</h3>
        <div class="bg-slate-800 rounded-lg p-4 mb-6 overflow-x-auto">
          <pre class="text-sm text-gray-300"><code>curl -X POST "https://api.trandor.com/v1/chat/completions" \
  -H "Content-Type: application/json" \
  -H "X-NWC: nostr+walletconnect://WALLET_PUBKEY?relay=wss://relay.example.com&secret=YOUR_SECRET" \
  -d '{
    "model": "gpt-4.1",
    "messages": [
      {"role": "user", "content": "What is Bitcoin?"}
    ],
    "max_tokens": 100
  }'</code></pre>
        </div>
      </div>
    </section>

    <!-- API Reference -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x1F4D6;</span> API Reference
      </h2>

      <div class="space-y-8">
        <!-- List Models -->
        <div class="bg-slate-800 rounded-lg p-6">
          <div class="flex items-center gap-2 mb-4">
            <span class="bg-blue-600 text-white text-xs font-bold px-2 py-1 rounded">GET</span>
            <code class="text-yellow-400">/v1/models</code>
          </div>
          <p class="text-gray-300 mb-4">Returns list of available models. No authentication required.</p>
          <h4 class="text-white font-semibold mb-3">Response</h4>
          <div class="bg-slate-900 rounded p-4 overflow-x-auto">
            <pre class="text-sm text-gray-300"><code>{"models": ["gpt-4.1", "gpt-4.1-mini", ...]}</code></pre>
          </div>
        </div>

        <!-- Chat Completions -->
        <div class="bg-slate-800 rounded-lg p-6">
          <div class="flex items-center gap-2 mb-4">
            <span class="bg-green-600 text-white text-xs font-bold px-2 py-1 rounded">POST</span>
            <code class="text-yellow-400">/v1/chat/completions</code>
          </div>

          <h4 class="text-white font-semibold mb-3">Headers</h4>
          <table class="w-full text-sm mb-6">
            <thead>
              <tr class="text-left text-gray-400 border-b border-slate-700">
                <th class="pb-2">Header</th>
                <th class="pb-2">Required</th>
                <th class="pb-2">Description</th>
              </tr>
            </thead>
            <tbody class="text-gray-300">
              <tr class="border-b border-slate-700">
                <td class="py-2"><code class="text-yellow-400">X-NWC</code></td>
                <td class="py-2">Yes</td>
                <td class="py-2">Your NWC connection string (nostr+walletconnect://...)</td>
              </tr>
              <tr>
                <td class="py-2"><code class="text-yellow-400">Content-Type</code></td>
                <td class="py-2">Yes</td>
                <td class="py-2">application/json</td>
              </tr>
            </tbody>
          </table>

          <h4 class="text-white font-semibold mb-3">Request Body</h4>
          <div class="bg-slate-900 rounded p-4 mb-6 overflow-x-auto">
            <pre class="text-sm text-gray-300"><code>{
  "model": "gpt-4.1",            // Required: model ID from /v1/models
  "messages": [                   // Required: conversation history
    {"role": "system", "content": "You are a helpful assistant."},
    {"role": "user", "content": "Hello!"}
  ],
  "max_tokens": 1000,            // Optional: max tokens in response (default 4096)
  "temperature": 0.7             // Optional: randomness 0-2 (default 1)
}</code></pre>
          </div>

          <h4 class="text-white font-semibold mb-3">Response Headers</h4>
          <table class="w-full text-sm mb-6">
            <thead>
              <tr class="text-left text-gray-400 border-b border-slate-700">
                <th class="pb-2">Header</th>
                <th class="pb-2">Description</th>
              </tr>
            </thead>
            <tbody class="text-gray-300">
              <tr class="border-b border-slate-700">
                <td class="py-2"><code class="text-yellow-400">X-Charged-Sats</code></td>
                <td class="py-2">Amount charged upfront (2x estimate)</td>
              </tr>
              <tr class="border-b border-slate-700">
                <td class="py-2"><code class="text-yellow-400">X-Cost-Sats</code></td>
                <td class="py-2">Actual cost of the request</td>
              </tr>
              <tr class="border-b border-slate-700">
                <td class="py-2"><code class="text-yellow-400">X-Cost-USD</code></td>
                <td class="py-2">Actual cost in USD</td>
              </tr>
              <tr class="border-b border-slate-700">
                <td class="py-2"><code class="text-yellow-400">X-Refund-Sats</code></td>
                <td class="py-2">Amount refunded to your wallet</td>
              </tr>
              <tr>
                <td class="py-2"><code class="text-yellow-400">X-Refund-Status</code></td>
                <td class="py-2">success, failed, or none</td>
              </tr>
            </tbody>
          </table>

          <h4 class="text-white font-semibold mb-3">Response Body</h4>
          <p class="text-gray-400 text-sm">OpenAI-compatible chat completion response</p>
        </div>

        <!-- Streaming -->
        <div class="bg-slate-800 rounded-lg p-6">
          <div class="flex items-center gap-2 mb-4">
            <span class="bg-green-600 text-white text-xs font-bold px-2 py-1 rounded">POST</span>
            <code class="text-yellow-400">/v1/chat/completions/stream</code>
          </div>
          <p class="text-gray-300 mb-4">Same as above but returns Server-Sent Events stream with token-by-token response.</p>
          <h4 class="text-white font-semibold mb-3">SSE Events</h4>
          <ul class="text-gray-300 text-sm space-y-2">
            <li><code class="text-yellow-400">event: step</code> - Processing step updates (wallet_connect, moderation, payment, etc.)</li>
            <li><code class="text-yellow-400">event: token</code> - Individual response tokens as they're generated</li>
            <li><code class="text-yellow-400">event: complete</code> - Final response with cost breakdown</li>
            <li><code class="text-yellow-400">event: error</code> - Error message if something fails</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Content Moderation -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x26A0;</span> Content Moderation
      </h2>

      <div class="bg-amber-900/20 border border-amber-500/30 rounded-lg p-6">
        <p class="text-gray-300 mb-4">
          <strong class="text-amber-400">All requests are checked by OpenAI's moderation API before processing.</strong>
        </p>

        <h4 class="text-white font-semibold mb-3">Why We Moderate</h4>
        <p class="text-gray-400 mb-4">
          Trandor uses OpenAI's API to provide AI responses. OpenAI requires all API users to prevent misuse.
          If we allow content that violates OpenAI's usage policies, our API access will be revoked and this service
          will stop working for everyone.
        </p>

        <h4 class="text-white font-semibold mb-3">What Gets Flagged</h4>
        <ul class="text-gray-400 text-sm space-y-1 mb-4">
          <li>&#x2022; Violence and threats</li>
          <li>&#x2022; Hate speech and discrimination</li>
          <li>&#x2022; Self-harm content</li>
          <li>&#x2022; Sexual content involving minors</li>
          <li>&#x2022; Illegal activities</li>
        </ul>

        <h4 class="text-white font-semibold mb-3">What Happens on Violation</h4>
        <p class="text-gray-400 text-sm">
          Flagged requests are rejected with HTTP 400 and error code <code class="text-yellow-400">content_violation</code>.
          Your wallet is <strong>not charged</strong> for rejected requests.
          Repeated violations from the same NWC connection may result in blocking.
        </p>
      </div>
    </section>

    <!-- Payment Flow -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x26A1;</span> Payment Flow
      </h2>

      <div class="bg-slate-800 rounded-lg p-6">
        <ol class="space-y-4 text-gray-300">
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold">1</span>
            <div>
              <strong class="text-white">Estimate Cost</strong>
              <p class="text-sm text-gray-400">We estimate tokens based on input text length (~4 chars/token) and max_tokens</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold">2</span>
            <div>
              <strong class="text-white">Charge 2x Estimate</strong>
              <p class="text-sm text-gray-400">We create a Lightning invoice for 2x estimated cost as safety buffer</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold">3</span>
            <div>
              <strong class="text-white">NWC Pays Invoice</strong>
              <p class="text-sm text-gray-400">We use your NWC connection to request payment from your wallet</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold">4</span>
            <div>
              <strong class="text-white">AI Generates Response</strong>
              <p class="text-sm text-gray-400">Request forwarded to AI provider, response streamed or returned</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold">5</span>
            <div>
              <strong class="text-white">Calculate Actual Cost</strong>
              <p class="text-sm text-gray-400">Based on actual tokens used: (input_tokens × input_price + output_tokens × output_price) × 1.05</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold">6</span>
            <div>
              <strong class="text-white">Instant Refund</strong>
              <p class="text-sm text-gray-400">We request an invoice from your wallet via NWC and pay the difference</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- Pricing -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x1F4B0;</span> Pricing
      </h2>

      <p class="text-gray-400 mb-4">
        We charge OpenAI's prices plus 5% markup. Prices converted to satoshis at current BTC/USD rate.
      </p>

      <div class="bg-slate-800 rounded-lg p-4 mb-6 font-mono text-sm">
        <code class="text-yellow-400">cost_sats = (openai_price_usd × 1.05) ÷ (btc_price_usd ÷ 100,000,000)</code>
      </div>

      <p class="text-gray-400 text-sm">
        Check <code class="text-yellow-400">GET /v1/models</code> for current available models.
        Pricing varies by model - cheaper models like gpt-4.1-mini cost fractions of a satoshi per request.
      </p>
    </section>

    <!-- Integration Examples -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x1F4BB;</span> Integration Examples
      </h2>

      <div class="space-y-6">
        <div>
          <h4 class="text-white font-semibold mb-3">Python</h4>
          <div class="bg-slate-800 rounded-lg p-4 overflow-x-auto">
            <pre class="text-sm text-gray-300"><code>import requests

NWC_URL = "nostr+walletconnect://..."

response = requests.post(
    "https://api.trandor.com/v1/chat/completions",
    headers={
        "Content-Type": "application/json",
        "X-NWC": NWC_URL
    },
    json={
        "model": "gpt-4.1",
        "messages": [{"role": "user", "content": "Hello!"}]
    }
)

print(f"Cost: {response.headers.get('X-Cost-Sats')} sats")
print(f"Refund: {response.headers.get('X-Refund-Sats')} sats")
print(response.json()["choices"][0]["message"]["content"])</code></pre>
          </div>
        </div>

        <div>
          <h4 class="text-white font-semibold mb-3">JavaScript / Node.js</h4>
          <div class="bg-slate-800 rounded-lg p-4 overflow-x-auto">
            <pre class="text-sm text-gray-300"><code>const NWC_URL = "nostr+walletconnect://...";

const response = await fetch("https://api.trandor.com/v1/chat/completions", {
  method: "POST",
  headers: {
    "Content-Type": "application/json",
    "X-NWC": NWC_URL
  },
  body: JSON.stringify({
    model: "gpt-4.1",
    messages: [{ role: "user", content: "Hello!" }]
  })
});

console.log("Cost:", response.headers.get("X-Cost-Sats"), "sats");
console.log("Refund:", response.headers.get("X-Refund-Sats"), "sats");

const data = await response.json();
console.log(data.choices[0].message.content);</code></pre>
          </div>
        </div>

        <div>
          <h4 class="text-white font-semibold mb-3">cURL</h4>
          <div class="bg-slate-800 rounded-lg p-4 overflow-x-auto">
            <pre class="text-sm text-gray-300"><code>curl -X POST "https://api.trandor.com/v1/chat/completions" \
  -H "Content-Type: application/json" \
  -H "X-NWC: nostr+walletconnect://..." \
  -d '{"model":"gpt-4.1","messages":[{"role":"user","content":"Hello!"}]}' \
  -v 2>&1 | grep -E "(X-Cost|X-Refund|content)"</code></pre>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer class="py-8 border-t border-slate-700 mt-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-500 mb-2">
        &#x26A1; Trandor - AI API Gateway for Autonomous Agents
      </p>
      <p class="text-gray-600 text-sm">
        <a href="https://github.com/trandor/trandor" class="hover:text-yellow-400">Open Source</a>
        &bull; Self-host with 0% markup
      </p>
    </div>
  </footer>
</div>
