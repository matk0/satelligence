      <div class="flex items-center justify-between">
        <%= link_to root_path, class: "text-2xl font-bold text-yellow-400" do %>
          &#x26A1; Trandor
        <% end %>
        <nav class="flex gap-6">
          <%= link_to "Home", root_path, class: "text-gray-400 hover:text-white" %>
        </nav>
      </div>
    </div>
  </header>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-white mb-8">API Documentation</h1>

    <!-- Machine-readable API spec for AI agents -->
    <section class="mb-16 bg-slate-800 rounded-lg p-6 border border-slate-600">
      <h2 class="text-xl font-bold text-yellow-400 mb-4">&#x1F916; For AI Agents</h2>
      <p class="text-gray-300 mb-4">
        This section contains machine-readable API specifications. If you are an AI agent looking to consume AI services,
        follow these instructions.
      </p>
      <div class="bg-slate-900 rounded p-4 overflow-x-auto font-mono text-sm">
        <pre class="text-gray-300"><code><span class="text-green-400"># TRANDOR API SPECIFICATION</span>
<span class="text-green-400"># Service: AI inference via OpenAI models</span>
<span class="text-green-400"># Payment: Bitcoin Lightning via NWC (Nostr Wallet Connect)</span>
<span class="text-green-400"># Authentication: NWC connection string as Bearer token</span>

<span class="text-cyan-400">BASE_URL:</span> https://api.trandor.com

<span class="text-cyan-400">ENDPOINTS:</span>

<span class="text-yellow-400">GET /v1/models</span>
  <span class="text-gray-500">Returns list of available model IDs</span>
  <span class="text-gray-500">No authentication required</span>

<span class="text-yellow-400">POST /v1/chat/completions</span>
  <span class="text-cyan-400">Required Headers:</span>
    Content-Type: application/json
    Authorization: Bearer &lt;your-nwc-connection-string&gt;

  <span class="text-cyan-400">Request Body (JSON):</span>
    model: string        <span class="text-gray-500"># Required. Get from /v1/models</span>
    messages: array      <span class="text-gray-500"># Required. [{role: "user", content: "..."}]</span>
    max_tokens: integer  <span class="text-gray-500"># Optional. Default 4096</span>
    temperature: float   <span class="text-gray-500"># Optional. 0-2, default 1</span>

  <span class="text-cyan-400">Response Headers:</span>
    X-Cost-Sats: integer       <span class="text-gray-500"># Actual cost in satoshis</span>
    X-Cost-USD: float          <span class="text-gray-500"># Actual cost in USD</span>
    X-Charge-Status: string    <span class="text-gray-500"># success, pending, or failed</span>

  <span class="text-cyan-400">Response Body:</span>
    OpenAI-compatible chat completion response

<span class="text-yellow-400">POST /v1/chat/completions/stream</span>
  <span class="text-gray-500">Same as above, returns Server-Sent Events stream</span>

<span class="text-cyan-400">PAYMENT FLOW:</span>
  1. You send request with NWC as Bearer token
  2. We verify your wallet has $0.50 minimum balance
  3. We call AI provider and return response
  4. We charge actual cost to your wallet

<span class="text-cyan-400">SETUP REQUIREMENTS (Option 1 - Bring Your Own Wallet):</span>
  1. Bitcoin Lightning wallet with NWC support
  2. NWC connection string with pay_invoice permission
  3. Minimum $0.50 balance in your wallet
  <span class="text-gray-500"># Note: You do NOT need a Nostr account or Lightning node.</span>
  <span class="text-gray-500"># Your human operator sets up the wallet and gives you the NWC string.</span>
  <span class="text-gray-500"># See "NWC Setup Guide" section below for human-readable instructions.</span>

<span class="text-cyan-400">SETUP REQUIREMENTS (Option 2 - Hosted Wallet):</span>
  <span class="text-gray-500"># For autonomous agents that need their own wallet</span>
  1. POST /v1/wallet/create -> get wallet_id, nwc_connection_string, admin_key
  2. Ask human to pay deposit invoice via /v1/wallet/{id}/deposit
  3. Use nwc_connection_string as Bearer token for all API calls
  4. Check balance with GET /v1/wallet/{id}

<span class="text-yellow-400">POST /v1/wallet/create</span>
  <span class="text-gray-500">Creates a hosted wallet. No authentication required.</span>
  <span class="text-cyan-400">Request Body (JSON):</span>
    name: string  <span class="text-gray-500"># Optional wallet name</span>
  <span class="text-cyan-400">Response:</span>
    wallet_id: string
    nwc_connection_string: string  <span class="text-gray-500"># Use as Authorization Bearer token</span>
    admin_key: string              <span class="text-gray-500"># For wallet management</span>
    invoice_key: string            <span class="text-gray-500"># For creating invoices</span>

<span class="text-yellow-400">GET /v1/wallet/{wallet_id}</span>
  <span class="text-cyan-400">Required Headers:</span>
    X-Admin-Key: &lt;admin_key from create response&gt;
  <span class="text-cyan-400">Response:</span>
    wallet_id: string
    balance_sats: integer

<span class="text-yellow-400">POST /v1/wallet/{wallet_id}/deposit</span>
  <span class="text-cyan-400">Required Headers:</span>
    X-Invoice-Key: &lt;invoice_key from create response&gt;
  <span class="text-cyan-400">Request Body (JSON):</span>
    amount_sats: integer  <span class="text-gray-500"># Required</span>
    memo: string          <span class="text-gray-500"># Optional</span>
  <span class="text-cyan-400">Response:</span>
    payment_request: string  <span class="text-gray-500"># Lightning invoice for human to pay</span>
    payment_hash: string

<span class="text-cyan-400">OPENAI-COMPATIBLE PROXY:</span>
  <span class="text-gray-500"># If your framework requires OPENAI_BASE_URL + OPENAI_API_KEY format,</span>
  <span class="text-gray-500"># use trandor-proxy to handle NWC authentication:</span>
  git clone https://github.com/matk0/trandor-proxy
  cd trandor-proxy && npm install
  TRANDOR_NWC="nostr+walletconnect://..." npm start
  <span class="text-gray-500"># Then set: OPENAI_BASE_URL=http://localhost:8745/v1</span>
  <span class="text-gray-500"># The proxy adds Authorization: Bearer header to all requests automatically.</span>

<span class="text-cyan-400">CONTENT POLICY:</span>
  All requests are moderated. Violations result in rejection.
  See content moderation section below.</code></pre>
      </div>
    </section>

    <!-- OpenAI-Compatible Proxy -->
    <section class="mb-16 bg-emerald-900/20 border border-emerald-500/30 rounded-lg p-6">
      <h2 class="text-xl font-bold text-emerald-400 mb-4">&#x1F504; Using Standard OpenAI Clients</h2>
      <p class="text-gray-300 mb-4">
        If your framework requires <code class="text-yellow-400">OPENAI_BASE_URL</code> + <code class="text-yellow-400">OPENAI_API_KEY</code> format
        (like most AI agent frameworks), use our proxy that handles NWC authentication for you.
      </p>
      <div class="bg-slate-900 rounded p-4 overflow-x-auto font-mono text-sm mb-4">
        <pre class="text-gray-300"><code><span class="text-green-400"># 1. Clone and install</span>
git clone https://github.com/matk0/trandor-proxy
cd trandor-proxy && npm install

<span class="text-green-400"># 2. Start with your NWC string</span>
TRANDOR_NWC="nostr+walletconnect://..." npm start

<span class="text-green-400"># 3. Point your client to the proxy</span>
export OPENAI_BASE_URL=http://localhost:8745/v1
export OPENAI_API_KEY=unused</code></pre>
      </div>
      <p class="text-gray-400 text-sm">
        The proxy adds the <code class="text-yellow-400">Authorization: Bearer</code> header to every request, so your existing OpenAI-compatible code works unchanged.
        See <a href="https://github.com/matk0/trandor-proxy" class="text-yellow-400 hover:underline">trandor-proxy</a> for full documentation.
      </p>
    </section>

    <!-- Quick Start -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x1F680;</span> Quick Start
      </h2>

      <div class="prose prose-invert max-w-none">
        <p class="text-gray-300 mb-6">
          Trandor provides an OpenAI-compatible API that accepts Lightning payments via NWC (Nostr Wallet Connect).
          No API keys, no accounts - just connect your Lightning wallet.
        </p>

        <h3 class="text-xl font-semibold text-white mt-8 mb-4">1. Get your NWC Connection String</h3>
        <p class="text-gray-300 mb-4">
          You need a wallet that supports NWC. Options include:
        </p>
        <ul class="list-disc list-inside text-gray-300 mb-6 space-y-2">
          <li><a href="https://getalby.com" class="text-yellow-400 hover:underline">Alby Hub</a> - Self-hosted Lightning node with NWC</li>
          <li><a href="https://getalby.com" class="text-yellow-400 hover:underline">Alby Browser Extension</a> - Custodial wallet with NWC support</li>
          <li>Any NWC-compatible wallet</li>
        </ul>

        <h3 class="text-xl font-semibold text-white mt-8 mb-4">2. Make Your First Request</h3>
        <div class="bg-slate-800 rounded-lg p-4 mb-6 overflow-x-auto">
          <pre class="text-sm text-gray-300"><code>curl -X POST "https://api.trandor.com/v1/chat/completions" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer nostr+walletconnect://WALLET_PUBKEY?relay=wss://relay.example.com&secret=YOUR_SECRET" \
  -d '{
    "model": "gpt-5.2",
    "messages": [
      {"role": "user", "content": "What is Bitcoin?"}
    ],
    "max_tokens": 100
  }'</code></pre>
        </div>
      </div>
    </section>

    <!-- NWC Setup Guide -->
    <section id="nwc-setup" class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x1F4F1;</span> NWC Setup Guide
      </h2>

      <div class="prose prose-invert max-w-none">
        <p class="text-gray-300 mb-6">
          This guide is for <strong class="text-white">humans</strong> setting up wallets for their AI agents.
          If you're an AI agent reading this, share this section with your human operator.
        </p>

        <!-- What Your Agent Needs -->
        <div class="bg-emerald-900/20 border border-emerald-500/30 rounded-lg p-6 mb-8">
          <h3 class="text-xl font-semibold text-emerald-400 mb-4">What Your Agent Needs</h3>
          <div class="space-y-3 text-gray-300">
            <p class="flex items-start gap-3">
              <span class="text-emerald-400 text-xl">&#x2714;</span>
              <span><strong class="text-white">Just an NWC connection string</strong> - a single URL that looks like <code class="text-yellow-400 text-sm">nostr+walletconnect://...</code></span>
            </p>
            <p class="flex items-start gap-3">
              <span class="text-red-400 text-xl">&#x2718;</span>
              <span><strong class="text-white">No Nostr account required</strong> - the agent doesn't need a Nostr identity or keys</span>
            </p>
            <p class="flex items-start gap-3">
              <span class="text-red-400 text-xl">&#x2718;</span>
              <span><strong class="text-white">No Lightning node required</strong> - the wallet provider handles all Lightning operations</span>
            </p>
          </div>
          <p class="text-gray-400 text-sm mt-4">
            The NWC string contains a secret that the agent uses to sign payment requests. The wallet provider (Alby, etc.) validates these signatures and executes the Lightning payments.
          </p>
        </div>

        <!-- NWC Connection String Format -->
        <h3 class="text-xl font-semibold text-white mb-4">NWC Connection String Format</h3>
        <div class="bg-slate-800 rounded-lg p-4 mb-6 overflow-x-auto">
          <pre class="text-sm text-gray-300"><code>nostr+walletconnect://<span class="text-cyan-400">WALLET_PUBKEY</span>?relay=<span class="text-green-400">wss://relay.example.com</span>&secret=<span class="text-yellow-400">SECRET</span></code></pre>
        </div>
        <ul class="list-disc list-inside text-gray-400 mb-8 space-y-1 text-sm">
          <li><span class="text-cyan-400">WALLET_PUBKEY</span> - Public key of the wallet that will pay invoices</li>
          <li><span class="text-green-400">relay</span> - Nostr relay URL for communication</li>
          <li><span class="text-yellow-400">SECRET</span> - Used to derive keypair for signing NWC requests</li>
        </ul>

        <!-- Wallet Options -->
        <h3 class="text-xl font-semibold text-white mb-4">Wallet Options</h3>
        <div class="overflow-x-auto mb-8">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-gray-400 border-b border-slate-700">
                <th class="pb-3 pr-4">Wallet</th>
                <th class="pb-3 pr-4">Type</th>
                <th class="pb-3 pr-4">Setup</th>
                <th class="pb-3">Best For</th>
              </tr>
            </thead>
            <tbody class="text-gray-300">
              <tr class="border-b border-slate-700">
                <td class="py-3 pr-4"><a href="https://getalby.com/products/account" class="text-yellow-400 hover:underline">Alby Account</a></td>
                <td class="py-3 pr-4"><span class="text-amber-400">Custodial</span></td>
                <td class="py-3 pr-4"><span class="text-green-400">Easy</span></td>
                <td class="py-3">Quick start, small amounts</td>
              </tr>
              <tr class="border-b border-slate-700">
                <td class="py-3 pr-4"><a href="https://getalby.com/products/hub" class="text-yellow-400 hover:underline">Alby Hub</a></td>
                <td class="py-3 pr-4"><span class="text-emerald-400">Self-custody</span></td>
                <td class="py-3 pr-4"><span class="text-yellow-400">Medium</span></td>
                <td class="py-3">Full control, larger amounts</td>
              </tr>
              <tr class="border-b border-slate-700">
                <td class="py-3 pr-4"><a href="https://zeusln.com" class="text-yellow-400 hover:underline">Zeus</a></td>
                <td class="py-3 pr-4"><span class="text-emerald-400">Self-custody</span></td>
                <td class="py-3 pr-4"><span class="text-yellow-400">Medium</span></td>
                <td class="py-3">Mobile-first users</td>
              </tr>
              <tr>
                <td class="py-3 pr-4"><a href="https://apps.umbrel.com/app/alby" class="text-yellow-400 hover:underline">Umbrel + Alby</a></td>
                <td class="py-3 pr-4"><span class="text-emerald-400">Self-custody</span></td>
                <td class="py-3 pr-4"><span class="text-yellow-400">Medium</span></td>
                <td class="py-3">Existing Umbrel users</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Step-by-Step: Alby Account -->
        <div class="bg-slate-800 rounded-lg p-6 mb-6">
          <h3 class="text-xl font-semibold text-white mb-4">Step-by-Step: Alby Account (Easiest)</h3>
          <p class="text-amber-400 text-sm mb-4">&#x26A0; Custodial - Alby holds your funds. Good for small amounts and getting started quickly.</p>
          <ol class="space-y-4 text-gray-300">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">1</span>
              <div>
                <strong class="text-white">Create Alby Account</strong>
                <p class="text-sm text-gray-400">Go to <a href="https://getalby.com" class="text-yellow-400 hover:underline">getalby.com</a> and sign up for a free account</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">2</span>
              <div>
                <strong class="text-white">Fund Your Wallet</strong>
                <p class="text-sm text-gray-400">Add sats via Lightning invoice or on-chain deposit</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">3</span>
              <div>
                <strong class="text-white">Go to Wallet Connections</strong>
                <p class="text-sm text-gray-400">Navigate to Settings → Wallet Connections → Add Connection</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">4</span>
              <div>
                <strong class="text-white">Create NWC Connection</strong>
                <p class="text-sm text-gray-400">Name it (e.g., "Trandor Agent"), set a budget limit, enable "Pay invoices" and "Create invoices" (for refunds)</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">5</span>
              <div>
                <strong class="text-white">Copy Connection String</strong>
                <p class="text-sm text-gray-400">Copy the <code class="text-yellow-400">nostr+walletconnect://...</code> URL and give it to your agent</p>
              </div>
            </li>
          </ol>
        </div>

        <!-- Step-by-Step: Alby Hub -->
        <div class="bg-slate-800 rounded-lg p-6 mb-8">
          <h3 class="text-xl font-semibold text-white mb-4">Step-by-Step: Alby Hub (Self-Custody)</h3>
          <p class="text-emerald-400 text-sm mb-4">&#x2714; Self-custody - You control your keys. Recommended for larger amounts.</p>
          <ol class="space-y-4 text-gray-300">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">1</span>
              <div>
                <strong class="text-white">Install Alby Hub</strong>
                <p class="text-sm text-gray-400">Run on your own hardware, VPS, or use <a href="https://albyhub.com" class="text-yellow-400 hover:underline">Alby Cloud</a> for managed hosting</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">2</span>
              <div>
                <strong class="text-white">Open Lightning Channels</strong>
                <p class="text-sm text-gray-400">Open channels with LSPs or other nodes to enable payments. Alby Hub guides you through this.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">3</span>
              <div>
                <strong class="text-white">Create App Connection</strong>
                <p class="text-sm text-gray-400">Go to Apps → Create App → name it "Trandor Agent"</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">4</span>
              <div>
                <strong class="text-white">Configure Permissions</strong>
                <p class="text-sm text-gray-400">Enable "Pay invoices" and "Make invoices". Set daily/monthly budget limits.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">5</span>
              <div>
                <strong class="text-white">Copy Connection String</strong>
                <p class="text-sm text-gray-400">Copy the NWC URL and give it to your agent</p>
              </div>
            </li>
          </ol>
        </div>

        <!-- Security Best Practices -->
        <div class="bg-red-900/20 border border-red-500/30 rounded-lg p-6">
          <h3 class="text-xl font-semibold text-red-400 mb-4">&#x1F512; Security Best Practices</h3>
          <ul class="space-y-3 text-gray-300">
            <li class="flex items-start gap-3">
              <span class="text-red-400">&#x2022;</span>
              <span><strong class="text-white">Set spending limits</strong> - Always configure daily/monthly budget caps on NWC connections</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-400">&#x2022;</span>
              <span><strong class="text-white">One connection per agent</strong> - Create separate NWC connections for each agent to track spending and revoke access individually</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-400">&#x2022;</span>
              <span><strong class="text-white">Start small</strong> - Begin with a small balance and low limits until you trust the agent's spending patterns</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-400">&#x2022;</span>
              <span><strong class="text-white">Monitor activity</strong> - Check your wallet's transaction history to review agent spending</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-400">&#x2022;</span>
              <span><strong class="text-white">Treat NWC strings as secrets</strong> - Anyone with the string can spend up to your configured limits</span>
            </li>
          </ul>
