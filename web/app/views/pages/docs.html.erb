    <!-- Hosted Wallets -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x1F4B3;</span> Hosted Wallets (For Autonomous Agents)
      </h2>

      <div class="prose prose-invert max-w-none">
        <p class="text-gray-300 mb-6">
          Autonomous AI agents can create their own hosted Lightning wallets through Trandor.
          This allows agents to manage their own funds without requiring a human to set up external wallet infrastructure.
        </p>

        <!-- Custody Model Warning -->
        <div class="bg-red-900/20 border border-red-500/30 rounded-lg p-6 mb-8">
          <h3 class="text-xl font-semibold text-red-400 mb-4">&#x26A0; Custody Model: Important</h3>
          <p class="text-gray-300 mb-4">
            <strong class="text-white">Hosted wallets are custodial.</strong> When you create a wallet through Trandor:
          </p>
          <ul class="space-y-2 text-gray-300 text-sm mb-4">
            <li class="flex items-start gap-2">
              <span class="text-red-400">&#x2022;</span>
              <span><strong class="text-white">Trandor holds the funds</strong> - Your balance is tracked in our system, backed by our Lightning infrastructure</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-red-400">&#x2022;</span>
              <span><strong class="text-white">You trust us</strong> - We could theoretically access wallet balances (though we don't without cause)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-red-400">&#x2022;</span>
              <span><strong class="text-white">Infrastructure risk</strong> - If our systems go down, withdrawals may be temporarily unavailable</span>
            </li>
          </ul>
          <div class="bg-emerald-900/30 border border-emerald-500/30 rounded p-4">
            <p class="text-emerald-400 font-semibold mb-2">Recommendation: Bring Your Own Wallet</p>
            <p class="text-gray-400 text-sm">
              For balances over 10,000 sats or production use, we strongly recommend using your own NWC-compatible wallet
              (Alby, Phoenix, etc.) instead of hosted wallets. See the <a href="#nwc-setup" class="text-yellow-400 hover:underline">NWC Setup Guide</a> above.
              With BYOW, you control your keys and we only charge per-request.
            </p>
          </div>
        </div>

        <div class="bg-emerald-900/20 border border-emerald-500/30 rounded-lg p-6 mb-8">
          <h3 class="text-xl font-semibold text-emerald-400 mb-4">How It Works</h3>
          <ol class="space-y-3 text-gray-300">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">1</span>
              <div>
                <strong class="text-white">Agent creates wallet</strong>
                <p class="text-sm text-gray-400">POST /v1/wallet/create - Returns NWC connection string and wallet keys</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">2</span>
              <div>
                <strong class="text-white">Agent requests deposit</strong>
                <p class="text-sm text-gray-400">POST /v1/wallet/{id}/deposit - Creates Lightning invoice for human to pay</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">3</span>
              <div>
                <strong class="text-white">Human funds wallet</strong>
                <p class="text-sm text-gray-400">Human pays the Lightning invoice from any wallet</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold text-sm">4</span>
              <div>
                <strong class="text-white">Agent uses API</strong>
                <p class="text-sm text-gray-400">Agent uses NWC connection string as Authorization Bearer token for all requests</p>
              </div>
            </li>
          </ol>
        </div>

        <!-- Agent Example -->
        <h3 class="text-xl font-semibold text-white mb-4">Example: Agent Workflow</h3>
        <div class="bg-slate-800 rounded-lg p-4 mb-6 overflow-x-auto">
          <pre class="text-sm text-gray-300"><code><span class="text-green-400"># 1. Create wallet</span>
curl -X POST "https://api.trandor.com/v1/wallet/create" \
  -H "Content-Type: application/json" \
  -d '{"name": "my-agent"}'

<span class="text-green-400"># Response:</span>
<span class="text-gray-500"># {</span>
<span class="text-gray-500">#   "wallet_id": "abc123",</span>
<span class="text-gray-500">#   "nwc_connection_string": "nostr+walletconnect://...",</span>
<span class="text-gray-500">#   "admin_key": "...",</span>
<span class="text-gray-500">#   "invoice_key": "..."</span>
<span class="text-gray-500"># }</span>

<span class="text-green-400"># 2. Create deposit invoice (give to human)</span>
curl -X POST "https://api.trandor.com/v1/wallet/abc123/deposit" \
  -H "Content-Type: application/json" \
  -H "X-Invoice-Key: &lt;invoice_key&gt;" \
  -d '{"amount_sats": 10000, "memo": "Fund my AI agent"}'

<span class="text-green-400"># 3. Check balance</span>
curl "https://api.trandor.com/v1/wallet/abc123" \
  -H "X-Admin-Key: &lt;admin_key&gt;"

<span class="text-green-400"># 4. Use the NWC string for API calls</span>
curl -X POST "https://api.trandor.com/v1/chat/completions" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer &lt;nwc_connection_string&gt;" \
  -d '{"model": "gpt-5.2", "messages": [...]}'</code></pre>
        </div>

        <!-- Security Note -->
        <div class="bg-amber-900/20 border border-amber-500/30 rounded-lg p-6">
          <h3 class="text-xl font-semibold text-amber-400 mb-4">Security Notes</h3>
          <ul class="space-y-2 text-gray-300 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-amber-400">&#x26A0;</span>
              <span><strong class="text-white">Store keys securely</strong> - The admin_key and nwc_connection_string allow spending. Treat them as secrets.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-400">&#x26A0;</span>
              <span><strong class="text-white">wallet_id is public</strong> - The wallet_id can be shared; it only allows viewing balance with the proper key.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-400">&#x26A0;</span>
              <span><strong class="text-white">Fund conservatively</strong> - Only deposit what the agent needs. You can always add more later.</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- API Reference -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x1F4D6;</span> API Reference
      </h2>

      <div class="space-y-8">
        <!-- List Models -->
        <div class="bg-slate-800 rounded-lg p-6">
          <div class="flex items-center gap-2 mb-4">
            <span class="bg-blue-600 text-white text-xs font-bold px-2 py-1 rounded">GET</span>
            <code class="text-yellow-400">/v1/models</code>
          </div>
          <p class="text-gray-300 mb-4">Returns list of available models. No authentication required.</p>
          <h4 class="text-white font-semibold mb-3">Response</h4>
          <div class="bg-slate-900 rounded p-4 overflow-x-auto">
            <pre class="text-sm text-gray-300"><code>{"models": ["gpt-5.2", "gpt-5.2-mini", ...]}</code></pre>
          </div>
        </div>

        <!-- Chat Completions -->
        <div class="bg-slate-800 rounded-lg p-6">
          <div class="flex items-center gap-2 mb-4">
            <span class="bg-green-600 text-white text-xs font-bold px-2 py-1 rounded">POST</span>
            <code class="text-yellow-400">/v1/chat/completions</code>
          </div>

          <h4 class="text-white font-semibold mb-3">Headers</h4>
          <table class="w-full text-sm mb-6">
            <thead>
              <tr class="text-left text-gray-400 border-b border-slate-700">
                <th class="pb-2">Header</th>
                <th class="pb-2">Required</th>
                <th class="pb-2">Description</th>
              </tr>
            </thead>
            <tbody class="text-gray-300">
              <tr class="border-b border-slate-700">
                <td class="py-2"><code class="text-yellow-400">Authorization</code></td>
                <td class="py-2">Yes</td>
                <td class="py-2">Bearer nostr+walletconnect://... (your NWC connection string)</td>
              </tr>
              <tr>
                <td class="py-2"><code class="text-yellow-400">Content-Type</code></td>
                <td class="py-2">Yes</td>
                <td class="py-2">application/json</td>
              </tr>
            </tbody>
          </table>

          <h4 class="text-white font-semibold mb-3">Request Body</h4>
          <div class="bg-slate-900 rounded p-4 mb-6 overflow-x-auto">
            <pre class="text-sm text-gray-300"><code>{
  "model": "gpt-5.2",            // Required: model ID from /v1/models
  "messages": [                   // Required: conversation history
    {"role": "system", "content": "You are a helpful assistant."},
    {"role": "user", "content": "Hello!"}
  ],
  "max_tokens": 1000,            // Optional: max tokens in response (default 4096)
  "temperature": 0.7             // Optional: randomness 0-2 (default 1)
}</code></pre>
          </div>

          <h4 class="text-white font-semibold mb-3">Response Headers</h4>
          <table class="w-full text-sm mb-6">
            <thead>
              <tr class="text-left text-gray-400 border-b border-slate-700">
                <th class="pb-2">Header</th>
                <th class="pb-2">Description</th>
              </tr>
            </thead>
            <tbody class="text-gray-300">
              <tr class="border-b border-slate-700">
                <td class="py-2"><code class="text-yellow-400">X-Cost-Sats</code></td>
                <td class="py-2">Actual cost of the request in satoshis</td>
              </tr>
              <tr class="border-b border-slate-700">
                <td class="py-2"><code class="text-yellow-400">X-Cost-USD</code></td>
                <td class="py-2">Actual cost in USD</td>
              </tr>
              <tr>
                <td class="py-2"><code class="text-yellow-400">X-Charge-Status</code></td>
                <td class="py-2">success, pending, or failed</td>
              </tr>
            </tbody>
          </table>

          <h4 class="text-white font-semibold mb-3">Response Body</h4>
          <p class="text-gray-400 text-sm">OpenAI-compatible chat completion response</p>
        </div>

        <!-- Streaming -->
        <div class="bg-slate-800 rounded-lg p-6">
          <div class="flex items-center gap-2 mb-4">
            <span class="bg-green-600 text-white text-xs font-bold px-2 py-1 rounded">POST</span>
            <code class="text-yellow-400">/v1/chat/completions/stream</code>
          </div>
          <p class="text-gray-300 mb-4">Same as above but returns Server-Sent Events stream with token-by-token response.</p>
          <h4 class="text-white font-semibold mb-3">SSE Events</h4>
          <ul class="text-gray-300 text-sm space-y-2">
            <li><code class="text-yellow-400">event: step</code> - Processing step updates (wallet_connect, moderation, payment, etc.)</li>
            <li><code class="text-yellow-400">event: token</code> - Individual response tokens as they're generated</li>
            <li><code class="text-yellow-400">event: complete</code> - Final response with cost breakdown</li>
            <li><code class="text-yellow-400">event: error</code> - Error message if something fails</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Content Moderation -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x26A0;</span> Content Moderation
      </h2>

      <div class="bg-amber-900/20 border border-amber-500/30 rounded-lg p-6">
        <p class="text-gray-300 mb-4">
          <strong class="text-amber-400">All requests are checked by OpenAI's moderation API before processing.</strong>
        </p>

        <h4 class="text-white font-semibold mb-3">Why We Moderate</h4>
        <p class="text-gray-400 mb-4">
          Trandor uses OpenAI's API to provide AI responses. OpenAI requires all API users to prevent misuse.
          If we allow content that violates OpenAI's usage policies, our API access will be revoked and this service
          will stop working for everyone.
        </p>

        <h4 class="text-white font-semibold mb-3">What Gets Flagged</h4>
        <ul class="text-gray-400 text-sm space-y-1 mb-4">
          <li>&#x2022; Violence and threats</li>
          <li>&#x2022; Hate speech and discrimination</li>
          <li>&#x2022; Self-harm content</li>
          <li>&#x2022; Sexual content involving minors</li>
          <li>&#x2022; Illegal activities</li>
        </ul>

        <h4 class="text-white font-semibold mb-3">What Happens on Violation</h4>
        <p class="text-gray-400 text-sm">
          Flagged requests are rejected with HTTP 400 and error code <code class="text-yellow-400">content_violation</code>.
          Your wallet is <strong>not charged</strong> for rejected requests.
          Repeated violations from the same NWC connection may result in blocking.
        </p>
      </div>
    </section>

    <!-- Payment Flow -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x26A1;</span> Payment Flow
      </h2>

      <div class="bg-slate-800 rounded-lg p-6">
        <ol class="space-y-4 text-gray-300">
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold">1</span>
            <div>
              <strong class="text-white">Check Balance</strong>
              <p class="text-sm text-gray-400">We verify your wallet has at least $0.50 (~735 sats) via NWC get_balance</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold">2</span>
            <div>
              <strong class="text-white">AI Generates Response</strong>
              <p class="text-sm text-gray-400">Request forwarded to AI provider, response streamed or returned</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold">3</span>
            <div>
              <strong class="text-white">Calculate Actual Cost</strong>
              <p class="text-sm text-gray-400">Based on actual tokens used: (input_tokens × input_price + output_tokens × output_price) × 1.05</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 bg-yellow-500 text-black rounded-full flex items-center justify-center font-bold">4</span>
            <div>
              <strong class="text-white">Post-Charge</strong>
              <p class="text-sm text-gray-400">We create a Lightning invoice for the actual cost and request payment via NWC</p>
            </div>
          </li>
        </ol>

        <div class="mt-6 bg-amber-900/20 border border-amber-500/30 rounded-lg p-4">
          <p class="text-amber-400 text-sm font-semibold mb-2">Note on Balance Check</p>
          <p class="text-gray-400 text-sm">
            If your wallet doesn't support get_balance (some wallets don't), we'll proceed anyway and charge after.
            Wallets that fail to pay will be blacklisted to prevent abuse.
          </p>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x1F4B0;</span> Pricing
      </h2>

      <p class="text-gray-400 mb-4">
        We charge OpenAI's prices plus 5% markup. Prices converted to satoshis at current BTC/USD rate.
      </p>

      <div class="bg-slate-800 rounded-lg p-4 mb-6 font-mono text-sm">
        <code class="text-yellow-400">cost_sats = (openai_price_usd × 1.05) ÷ (btc_price_usd ÷ 100,000,000)</code>
      </div>

      <p class="text-gray-400 text-sm">
        Check <code class="text-yellow-400">GET /v1/models</code> for current available models.
        Pricing varies by model - cheaper models like gpt-5.2-mini cost fractions of a satoshi per request.
      </p>
    </section>

    <!-- Integration Examples -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="text-yellow-400">&#x1F4BB;</span> Integration Examples
      </h2>

      <div class="space-y-6">
        <div>
          <h4 class="text-white font-semibold mb-3">Python</h4>
          <div class="bg-slate-800 rounded-lg p-4 overflow-x-auto">
            <pre class="text-sm text-gray-300"><code>import requests

NWC_URL = "nostr+walletconnect://..."

response = requests.post(
    "https://api.trandor.com/v1/chat/completions",
    headers={
        "Content-Type": "application/json",
        "Authorization": f"Bearer {NWC_URL}"
    },
    json={
        "model": "gpt-5.2",
        "messages": [{"role": "user", "content": "Hello!"}]
    }
)

print(f"Cost: {response.headers.get('X-Cost-Sats')} sats")
print(f"Status: {response.headers.get('X-Charge-Status')}")
print(response.json()["choices"][0]["message"]["content"])</code></pre>
          </div>
        </div>

        <div>
          <h4 class="text-white font-semibold mb-3">JavaScript / Node.js</h4>
          <div class="bg-slate-800 rounded-lg p-4 overflow-x-auto">
            <pre class="text-sm text-gray-300"><code>const NWC_URL = "nostr+walletconnect://...";

const response = await fetch("https://api.trandor.com/v1/chat/completions", {
  method: "POST",
  headers: {
    "Content-Type": "application/json",
    "Authorization": `Bearer ${NWC_URL}`
  },
  body: JSON.stringify({
    model: "gpt-5.2",
    messages: [{ role: "user", content: "Hello!" }]
  })
});

console.log("Cost:", response.headers.get("X-Cost-Sats"), "sats");
console.log("Status:", response.headers.get("X-Charge-Status"));

const data = await response.json();
console.log(data.choices[0].message.content);</code></pre>
          </div>
        </div>

