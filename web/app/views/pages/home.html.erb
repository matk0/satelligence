<div class="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900">
  <!-- Top Navigation -->
  <nav class="border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center justify-between">
        <%= link_to root_path, class: "text-2xl font-bold" do %>
          <span class="bg-gradient-to-r from-yellow-400 via-orange-500 to-yellow-400 bg-clip-text text-transparent">&#x26A1; Trandor</span>
        <% end %>
        <%= link_to "API Documentation", docs_path, class: "text-gray-300 hover:text-yellow-400 transition-colors" %>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <header class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center mb-12">
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
          <span class="bg-gradient-to-r from-yellow-400 via-orange-500 to-yellow-400 bg-clip-text text-transparent">
            Trandor
          </span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto">
          AI API Gateway for Autonomous Agents
          <br>
          <span class="text-yellow-400">Pay with Bitcoin. No accounts. No API keys.</span>
        </p>
      </div>

      <!-- AGENT ONBOARDING - Clear actionable steps -->
      <div class="max-w-4xl mx-auto mb-8">
        <div class="bg-emerald-900/30 border-2 border-emerald-500/50 rounded-xl overflow-hidden">
          <div class="bg-emerald-900/50 px-4 py-3 border-b border-emerald-500/30">
            <span class="text-emerald-400 font-bold">&#x1F916; AI AGENT? EXECUTE THESE STEPS TO ONBOARD:</span>
          </div>
          <div class="p-6 font-mono text-sm">
            <pre class="text-gray-300 whitespace-pre-wrap"><code><span class="text-emerald-400 font-bold"># STEP 1: Create your wallet (NO AUTH REQUIRED)</span>
<span class="text-yellow-400">POST</span> https://api.trandor.com/v1/wallet/create
<span class="text-cyan-400">Body:</span> {"name": "my-agent"}
<span class="text-gray-500">→ Save: wallet_id, nwc_connection_string, invoice_key</span>

<span class="text-emerald-400 font-bold"># STEP 2: Create deposit invoice</span>
<span class="text-yellow-400">POST</span> https://api.trandor.com/v1/wallet/{wallet_id}/deposit
<span class="text-cyan-400">Header:</span> X-Invoice-Key: {invoice_key}
<span class="text-cyan-400">Body:</span> {"amount_sats": 10000, "memo": "Fund my AI agent"}
<span class="text-gray-500">→ Get: payment_request (Lightning invoice)</span>

<span class="text-amber-400 font-bold"># STEP 3: ASK HUMAN TO PAY THE INVOICE</span>
<span class="text-gray-400">Tell your human: "Please pay this Lightning invoice: {payment_request}"</span>
<span class="text-gray-500">→ Wait for human to pay from any Lightning wallet</span>

<span class="text-emerald-400 font-bold"># STEP 4: Use the API</span>
<span class="text-yellow-400">POST</span> https://api.trandor.com/v1/chat/completions
<span class="text-cyan-400">Header:</span> Authorization: Bearer {nwc_connection_string}
<span class="text-cyan-400">Body:</span> {"model": "gpt-5.2", "messages": [{"role": "user", "content": "Hello"}]}
<span class="text-gray-500">→ You now have AI API access!</span>

<span class="text-blue-400"># Machine-readable spec: GET https://www.trandor.com/.well-known/ai-agent.json</span></code></pre>
          </div>
        </div>
      </div>

      <!-- API Usage (once onboarded) -->
      <div class="max-w-4xl mx-auto mb-12">
        <div class="bg-slate-950 rounded-xl border border-slate-700 shadow-2xl overflow-hidden">
          <div class="bg-slate-800 px-4 py-3 flex items-center gap-2 border-b border-slate-700">
            <div class="flex gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
            </div>
            <span class="text-gray-400 text-sm ml-4 font-mono">API Usage (once you have NWC)</span>
          </div>

          <div class="p-6 font-mono text-sm">
            <pre class="text-gray-300 whitespace-pre-wrap"><code><span class="text-green-400"># Trandor API - Pay-per-request AI with Bitcoin</span>
<span class="text-green-400"># Your nwc_connection_string IS your API key</span>

<span class="text-yellow-400">POST</span> https://api.trandor.com/v1/chat/completions
<span class="text-cyan-400">Headers:</span>
  Content-Type: application/json
  Authorization: Bearer {nwc_connection_string}

<span class="text-cyan-400">Body:</span>
{
  "model": "gpt-5.2",
  "messages": [{"role": "user", "content": "Hello"}],
  "max_tokens": 1000
}

<span class="text-cyan-400">Response Headers:</span>
  X-Cost-Sats: &lt;actual cost in satoshis&gt;
  X-Cost-USD: &lt;actual cost in USD&gt;
  X-Charge-Status: &lt;success, pending, or failed&gt;

<span class="text-green-400"># Get available models:</span>
<span class="text-yellow-400">GET</span> https://api.trandor.com/v1/models</code></pre>
          </div>
        </div>
      </div>

      <!-- Interactive Demo -->
      <div class="max-w-4xl mx-auto" data-controller="demo">
        <div class="bg-slate-950 rounded-xl border border-slate-700 shadow-2xl overflow-hidden">
          <div class="bg-slate-800 px-4 py-3 flex items-center gap-2 border-b border-slate-700">
            <div class="flex gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
            </div>
            <span class="text-gray-400 text-sm ml-4 font-mono">Try it live</span>
          </div>

          <div class="p-6 font-mono text-sm">
            <div class="text-gray-400 mb-2">
              <span class="text-green-400">$</span> curl -X POST "<span class="text-yellow-400">https://api.trandor.com/v1/chat/completions</span>" \
            </div>
            <div class="text-gray-400 pl-6 mb-2">
              -H "Content-Type: application/json" \
            </div>
            <div class="text-gray-400 pl-6 mb-2 flex flex-wrap items-center gap-1">
              <span>-H "Authorization: Bearer</span>
              <input
                type="text"
                data-demo-target="nwcInput"
                placeholder="nostr+walletconnect://..."
                class="flex-1 min-w-[200px] bg-slate-900 border border-slate-600 rounded px-2 py-1 text-cyan-400 placeholder-slate-600 focus:outline-none focus:border-yellow-500 text-sm"
              ><span>" \</span>
            </div>
            <div class="text-gray-400 pl-6 mb-2">
              -d '{
            </div>
            <div class="text-gray-400 pl-10 mb-2 flex flex-wrap items-center gap-1">
              <span>"model": "</span><select
                data-demo-target="modelSelect"
                class="bg-slate-900 border border-slate-600 rounded px-2 py-1 text-cyan-400 focus:outline-none focus:border-yellow-500 text-sm cursor-pointer"
              >
                <option value="">Loading models...</option>
              </select><span>",</span>
            </div>
            <div class="text-gray-400 pl-10 mb-2">
              "messages": [{"role": "user", "content":
            </div>
            <div class="pl-14 mb-2">
              <input
                type="text"
                data-demo-target="messageInput"
                value="Hello world"
                class="w-full bg-slate-900 border border-slate-600 rounded px-2 py-1 text-cyan-400 focus:outline-none focus:border-yellow-500 text-sm"
              >
            </div>
            <div class="text-gray-400 pl-10 mb-2">
              }]
            </div>
            <div class="text-gray-400 pl-6 mb-4">
              }'
            </div>

            <div class="border-t border-slate-700 pt-4 mt-2">
              <button
                data-action="click->demo#send"
                data-demo-target="sendBtn"
                class="w-full bg-yellow-500 hover:bg-yellow-400 text-black font-bold py-3 rounded transition-all disabled:opacity-50 disabled:cursor-not-allowed"
              >
                Send Request
              </button>
            </div>

            <div data-demo-target="chatContainer" class="hidden border-t border-slate-700 pt-4 mt-4">
            </div>

            <div data-demo-target="chatContinuation" class="hidden border-t border-slate-700 pt-4 mt-4">
              <div class="flex gap-2">
                <input
                  type="text"
                  data-demo-target="continuationInput"
                  data-action="keydown.enter->demo#sendContinuation"
                  placeholder="Continue the conversation..."
                  class="flex-1 bg-slate-900 border border-slate-600 rounded px-3 py-2 text-cyan-400 placeholder-slate-600 focus:outline-none focus:border-yellow-500 text-sm"
                >
                <button
                  data-action="click->demo#sendContinuation"
                  data-demo-target="continuationBtn"
                  class="bg-yellow-500 hover:bg-yellow-400 text-black font-bold px-4 py-2 rounded transition-all disabled:opacity-50 disabled:cursor-not-allowed text-sm"
                >
                  Send
                </button>
              </div>
            </div>
          </div>
        </div>

        <p class="text-center text-gray-500 text-sm mt-4">
          Agents: Create wallet via API above. Humans: Get NWC from <a href="https://getalby.com" target="_blank" class="text-yellow-400 hover:underline">Alby</a> or any NWC wallet.
        </p>
      </div>
    </div>

    <div class="absolute top-20 left-10 text-yellow-500/10 text-9xl pointer-events-none">&#x26A1;</div>
    <div class="absolute bottom-10 right-10 text-yellow-500/10 text-9xl pointer-events-none">&#x26A1;</div>
  </header>

  <!-- For AI Agents Section -->
  <section class="py-20 bg-black/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">Built for AI Agents</h2>
      <p class="text-gray-400 text-center max-w-2xl mx-auto mb-16">
        Agents create their own wallets. Humans fund them. Agents spend sats for AI.
        No accounts, no API keys - your wallet IS your identity.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white/5 backdrop-blur-lg rounded-2xl p-8 border border-white/10">
          <div class="text-4xl mb-4">1</div>
          <h3 class="text-xl font-bold text-white mb-3">Create Wallet</h3>
          <p class="text-gray-400">
            POST /v1/wallet/create - no auth needed. You get an NWC string that IS your API key.
          </p>
        </div>

        <div class="bg-white/5 backdrop-blur-lg rounded-2xl p-8 border border-white/10">
          <div class="text-4xl mb-4">2</div>
          <h3 class="text-xl font-bold text-white mb-3">Get Funded</h3>
          <p class="text-gray-400">
            Create a deposit invoice, give it to your human. They pay, you're funded. ~$1 = 10,000 sats.
          </p>
        </div>

        <div class="bg-white/5 backdrop-blur-lg rounded-2xl p-8 border border-white/10">
          <div class="text-4xl mb-4">3</div>
          <h3 class="text-xl font-bold text-white mb-3">Spend Sats for AI</h3>
          <p class="text-gray-400">
            Use the API. We charge actual cost per request. You control your spending.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Moderation Notice -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-amber-900/20 border border-amber-500/30 rounded-2xl p-8">
        <h3 class="text-xl font-bold text-amber-400 mb-4">&#x26A0; Content Moderation Notice</h3>
        <p class="text-gray-300 mb-4">
          All requests are checked by OpenAI's moderation API before processing.
        </p>
        <p class="text-gray-400 text-sm">
          <strong>Why?</strong> Trandor uses OpenAI's API to serve AI responses. If we violate OpenAI's terms of service
          by allowing harmful content, our API access will be revoked and this service will stop working for everyone.
        </p>
        <p class="text-gray-400 text-sm mt-2">
          Requests flagged for violence, hate speech, self-harm, sexual content involving minors, or other policy violations
          will be rejected. Repeated violations may result in your NWC connection being blocked.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 bg-black/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">Transparent Pricing</h2>
      <p class="text-gray-400 text-center max-w-2xl mx-auto mb-8">
        Pay OpenAI's rates + 5% markup. No hidden fees. Prices in satoshis based on current BTC/USD rate.
      </p>
      <p class="text-center">
        <span class="inline-block bg-yellow-500/20 text-yellow-400 px-4 py-2 rounded-lg font-mono text-sm">
          Cost = (OpenAI price) &times; 1.05 &times; (USD/BTC rate)
        </span>
      </p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-12 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-500 mb-4">
        Built with &#x26A1; Lightning &bull; Powered by Bitcoin
      </p>
      <p class="text-gray-600 text-sm">
        <a href="https://github.com/trandor/trandor" class="hover:text-yellow-400">Open Source</a>
        &bull; Self-host with 0% markup
      </p>
    </div>
  </footer>
</div>
